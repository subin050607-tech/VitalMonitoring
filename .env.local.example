# ── Supabase 연결 (필수) ──────────────────────────────────────────────────
# 이 앱은 라이브 전용이다. 아래 두 값이 있어야 로그인·데이터가 동작한다.
# (값이 없으면 로그인 화면에서 "서버가 구성되지 않았습니다" 에러가 뜬다.)
#
# 설정:  cp .env.local.example .env.local  후 pnpm dev
# 값 위치:  Supabase 대시보드 → Project Settings → API
#   · URL = Project URL
#   · KEY = publishable/anon 키 (클라이언트 공개용, service_role 아님)
#
# ⚠️ 무료 티어는 미사용 시 자동 정지됨 → 시연 전 대시보드에서 활성 상태 확인.
# ⚠️ 현재 스키마는 RLS 가 느슨(자체 로그인)해 anon 키로 읽기가 열림 → 실서비스 전 강화 필요.

NEXT_PUBLIC_SUPABASE_URL=https://wvtzhzggvwfumjbqoskw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_t5fFAnEVKixIPCopp0LlCg_1jV2ZncO
