# ── 라이브 Supabase 연동 켜는 법 ──────────────────────────────────────────
# 1) Supabase 대시보드에서 프로젝트가 paused 면 Restore(복구)
# 2) supabase/recover_schema.sql + recover_seed.sql 적용
# 3) 이 파일을 .env.local 로 복사:   cp .env.local.example .env.local
# 4) pnpm dev  → 웹이 시뮬레이션 대신 실제 Supabase 뷰를 읽는다
#
# 값 둘 중 하나라도 비면 자동으로 시뮬레이션 모드로 폴백한다.
# 아래 anon 키는 VitalSigns 모바일 앱과 동일한 publishable(공개용) 키.
# 주의: 현재 스키마는 RLS 가 없어 anon 키로 환자정보가 열린다 → 실서비스 전 RLS 필수.
#
# ⚠️ 프로젝트를 새로 만들었다면 URL·키를 그 프로젝트 값으로 교체하고,
#    모바일 앱 MauiProgram.cs 의 url/key 도 같은 값으로 맞출 것.

NEXT_PUBLIC_SUPABASE_URL=https://snazttuhmwmpttdfaifo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_TybLOy80jAdAJ7Hpo1Iwhw_kPT0iXvh
